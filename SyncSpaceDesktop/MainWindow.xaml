<Window x:Class="SyncSpaceDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SyncSpace Desktop"
        Width="1440"
        Height="920"
        MinWidth="1024"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Background="#111827" Height="40">
            <TextBlock Text="SyncSpace" Foreground="#E5E7EB" VerticalAlignment="Center" Margin="14,0" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,8,0">
                <Button x:Name="BackButton" Content="←" Width="34" Height="26" Margin="2" Click="BackButton_Click" />
                <Button x:Name="ForwardButton" Content="→" Width="34" Height="26" Margin="2" Click="ForwardButton_Click" />
                <Button Content="Reload" Height="26" Margin="2" Padding="10,0" Click="ReloadButton_Click" />
                <Button Content="Home" Height="26" Margin="2" Padding="10,0" Click="HomeButton_Click" />
            </StackPanel>
        </DockPanel>

        <wv2:WebView2 x:Name="Browser" Grid.Row="1" />
    </Grid>
</Window>
