<Application x:Class="SyncSpaceDesktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0F172A" />
        <SolidColorBrush x:Key="Panel" Color="#111827" />
        <SolidColorBrush x:Key="Panel2" Color="#1F2937" />
        <SolidColorBrush x:Key="Text" Color="#E5E7EB" />
        <SolidColorBrush x:Key="Muted" Color="#94A3B8" />
        <SolidColorBrush x:Key="Accent" Color="#38BDF8" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Text}" /></Style>
        <Style TargetType="TextBox"><Setter Property="Margin" Value="0,4"/><Setter Property="Padding" Value="8"/></Style>
        <Style TargetType="PasswordBox"><Setter Property="Margin" Value="0,4"/><Setter Property="Padding" Value="8"/></Style>
        <Style TargetType="Button"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="10,6"/></Style>
        <Style TargetType="ListBox"><Setter Property="Background" Value="{StaticResource Panel}"/><Setter Property="Foreground" Value="{StaticResource Text}"/><Setter Property="BorderBrush" Value="#334155"/></Style>
    </Application.Resources>
</Application>
